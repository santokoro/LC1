<Window x:Class="LC1.MainWindow"
        Closing="Window_Closing"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compiler"
        AllowDrop="True"
        PreviewDragEnter="Window_DragEnter"
        PreviewDrop="Window_Drop"
        Width="1100" Height="750"
        MinWidth="900" MinHeight="600">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="New"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="Open"/>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="Save"/>
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="SaveAs"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="Undo"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="Redo"/>
        <KeyBinding Key="R" Modifiers="Ctrl" Command="Refresh"/>
        <KeyBinding Key="Q" Modifiers="Ctrl" Command="Close"/>
    </Window.InputBindings>

    <DockPanel>

        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Создать" Click="MenuNew_Click"/>
                <MenuItem Header="Открыть..." Click="MenuOpen_Click"/>
                <MenuItem Header="Сохранить" Click="MenuSave_Click"/>
                <MenuItem Header="Сохранить как..." Click="MenuSaveAs_Click"/>
                <Separator />
                <MenuItem Header="Выход" Click="MenuExit_Click"/>
            </MenuItem>

            <MenuItem Header="_Правка">
                <MenuItem Header="Назад" Command="ApplicationCommands.Undo"/>
                <MenuItem Header="Вперед" Command="ApplicationCommands.Redo"/>
                <Separator/>
                <MenuItem Header="Вырезать" Command="ApplicationCommands.Cut" CommandTarget="{Binding ElementName=EditorTextBox}"/>
                <MenuItem Header="Вставить" Command="ApplicationCommands.Paste" CommandTarget="{Binding ElementName=EditorTextBox}"/>
                <MenuItem Header="Копировать" Command="ApplicationCommands.Copy" CommandTarget="{Binding ElementName=EditorTextBox}"/>
                <MenuItem Header="Удалить" Command="ApplicationCommands.Delete" CommandTarget="{Binding ElementName=EditorTextBox}"/>
                <Separator/>
                <MenuItem Header="Выделить всё" Command="ApplicationCommands.SelectAll" CommandTarget="{Binding ElementName=EditorTextBox}"/>
            </MenuItem>

            <MenuItem Header="_Текст">
                <MenuItem Header="Постановка задачи" Click="MenuTaskStatement_Click"/>
                <MenuItem Header="Грамматика" Click="MenuGrammar_Click"/>
                <MenuItem Header="Классификация грамматики" Click="MenuClassification_Click"/>
                <MenuItem Header="Метод анализа" Click="MenuAnalysisMethod_Click"/>
                <MenuItem Header="Тестовый пример" Click="MenuTestExamples_Click"/>
                <MenuItem Header="Список литературы" Click="MenuLiterature_Click"/>
                <MenuItem Header="Исходный код программы" Click="MenuSourceCode_Click"/>
            </MenuItem>

            <MenuItem Header="_Пуск" Click="MenuRun_Click"/>

            <MenuItem Header="_Справка">
                <MenuItem Header="Вызов справки" Click="MenuHelp_Click"/>
                <MenuItem Header="О программе" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Name="StatusBarText" Text="Готово"/>
        </StatusBar>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button ToolTip ="Создать" Click="MenuNew_Click">
                    <Image Source="Images/new.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="Открыть" Click="MenuOpen_Click">
                    <Image Source="Images/open.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="Сохранить" Click="MenuSave_Click">
                    <Image Source="Images/save.png" Width="30" Height="30"/>
                </Button>

                <Button Content="ANTLR Parser" Click="RunAntlrParser_Click" />

                <Separator/>

                <Button ToolTip="Назад" Command="ApplicationCommands.Undo">
                    <Image Source="Images/back.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="Вперед" Command="ApplicationCommands.Redo">
                    <Image Source="Images/forward.png" Width="30" Height="30"/>
                </Button>

                <Separator/>

                <Button ToolTip="Копировать" Command="ApplicationCommands.Copy" CommandTarget="{Binding ElementName=EditorTextBox}">
                    <Image Source="Images/copy.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="Вырезать" Command="ApplicationCommands.Cut" CommandTarget="{Binding ElementName=EditorTextBox}">
                    <Image Source="Images/cut.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="Вставить" Command="ApplicationCommands.Paste" CommandTarget="{Binding ElementName=EditorTextBox}">
                    <Image Source="Images/enter.png" Width="30" Height="30"/>
                </Button>

                <Separator/>

                <Button ToolTip="Пуск" Click="MenuRun_Click">
                    <Image Source="Images/push2.png" Width="30" Height="30"/>
                </Button>

                <Separator/>

                <Button Content="Проверить Flex/Bison"
                        Width="180"
                        Height="30"
                        Margin="10"
                        Click="CheckFlexBison_Click"/>

                <Separator/>

                <Button ToolTip="Справка" Click="MenuHelp_Click">
                    <Image Source="Images/info2.png" Width="30" Height="30"/>
                </Button>

                <Button ToolTip="О программе" Click="MenuAbout_Click">
                    <Image Source="Images/info.png" Width="30" Height="30"/>
                </Button>

                <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                    <TextBox x:Name="FontSizeBox"
                             Width="27"
                             Text="14"
                             VerticalContentAlignment="Center"
                             HorizontalContentAlignment="Center"
                             TextChanged="FontSizeBox_TextChanged"
                             Height="23"/>

                    <StackPanel Orientation="Vertical" Margin="2,0,0,0">
                        <Button Height="18" Click="FontSizeUp_Click">▲</Button>
                        <Button Height="18" Click="FontSizeDown_Click">▼</Button>
                    </StackPanel>
                </StackPanel>

            </ToolBar>
        </ToolBarTray>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Name="LineNumbersScroll"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Name="LineNumbers"
                               FontFamily="Consolas"
                               FontSize="14"
                               TextAlignment="Right"
                               Margin="0,2,5,0"/>
                </ScrollViewer>

                <TextBox Grid.Column="1"
                         Name="EditorTextBox"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="14"
                         TextWrapping="NoWrap"
                         TextChanged="EditorTextBox_TextChanged"/>
            </Grid>

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center"
                          Background="Gray"
                          ShowsPreview="True"/>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TabControl Grid.Column="0">
                    <TabItem Header="Лексемы">
                        <DataGrid Name="TokensGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  MouseDoubleClick="TokensGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="60"/>
                                <DataGridTextColumn Header="Тип лексемы" Binding="{Binding Type}" Width="*"/>
                                <DataGridTextColumn Header="Лексема" Binding="{Binding Lexeme}" Width="150"/>
                                <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="200"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Ошибки">
                        <Grid>
                            <TextBlock x:Name="ErrorsOkText"
                                       Text="Анализ завершён успешно! Ошибок не обнаружено!"
                                       Margin="12"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Top"
                                       Visibility="Collapsed"/>
                            <DataGrid Name="ErrorGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      MouseDoubleClick="ErrorGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Неверный фрагмент" Binding="{Binding Fragment}" Width="*"/>
                                    <DataGridTextColumn Header="Местоположение" Binding="{Binding Location}" Width="120"/>
                                    <DataGridTextColumn Header="Описание" Binding="{Binding Message}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                </TabControl>

            </Grid>

        </Grid>

    </DockPanel>
</Window>